{
  "name": "Balboa - Gmail Watch Renewal (Every 6 Days)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 */6 * *"
            }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "Every 6 Days at 7 AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "notes": "Gmail watch expires after ~7 days. Renew every 6 days to be safe."
    },
    {
      "parameters": {
        "url": "https://balboa-xi.vercel.app/api/gmail/watch",
        "options": {
          "timeout": 30000
        }
      },
      "id": "renew-watch",
      "name": "Renew Gmail Watch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 300],
      "notes": "Requires user authentication cookie. May need service role alternative."
    }
  ],
  "connections": {
    "Every 6 Days at 7 AM": {
      "main": [
        [{ "node": "Renew Gmail Watch", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
